rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSynthrunUser() {
      return request.auth != null
        && request.auth.token.email.matches('.*@synthrun\\.site');
    }

    function ownsMessage(data) {
      return isSynthrunUser() && (
        data.recipientEmail == request.auth.token.email ||
        data.senderUid == request.auth.uid ||
        data.senderEmail == request.auth.token.email ||
        data.from == request.auth.token.email
      );
    }

    // Covers inbox, sent, archived, flagged, important, drafts, and trash.
    // Drafts are stored with recipientEmail = current user, so the same rules apply.
    // Trashed messages keep their original recipientEmail, so they remain accessible.
    // important field updates are treated like any other field update on owned messages.
    match /mail/{docId} {
      allow create: if isSynthrunUser()
        && (
          request.resource.data.recipientEmail == request.auth.token.email ||
          request.resource.data.senderEmail == request.auth.token.email ||
          request.resource.data.from == request.auth.token.email ||
          request.resource.data.senderUid == request.auth.uid
        );

      allow read, update, delete: if resource != null && ownsMessage(resource.data);
    }

    // User settings — each user can only read/write their own document
    match /user_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /labels/{labelId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /autoReplied/{hash} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /autoLabelRules/{ruleId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Dashboard users — each user can read their own; admins can read all
    match /dashboard_users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true
      );
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Team members — readable by all authenticated users; writable by admins only
    match /team_members/{memberId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Weekly plans — readable by all authenticated users; writable by own user or admins
    match /weekly_plans/{planId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == planId.split('_')[0] ||
        get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // Agendas — readable and writable by all synthrun.site users
    match /agendas/{agendaId} {
      allow read, write: if isSynthrunUser();
    }

    // Agenda items (canvas cards) — readable and writable by all synthrun.site users
    match /agenda_items/{itemId} {
      allow read, write: if isSynthrunUser();
    }

    // Meetings — readable by all synthrun.site users or anyone with a momId
    match /meetings/{meetingId} {
      allow read: if isSynthrunUser() || resource.data.momId != null;
      allow create: if isSynthrunUser();
      allow update: if isSynthrunUser() && (
        get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true
      );
      allow delete: if isSynthrunUser() && get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true;

      // Meet subcollections — participants, signals, messages
      match /participants/{uid} {
        allow read: if isSynthrunUser();
        allow create: if isSynthrunUser() && request.auth.uid == uid;
        allow update: if isSynthrunUser() && (
          request.auth.uid == uid ||
          get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostUid == request.auth.uid
        );
        allow delete: if isSynthrunUser() && (
          request.auth.uid == uid ||
          get(/databases/$(database)/documents/meetings/$(meetingId)).data.hostUid == request.auth.uid ||
          get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true
        );
      }

      match /signals/{signalId} {
        allow read: if isSynthrunUser();
        allow create: if isSynthrunUser();
        allow delete: if isSynthrunUser() && (resource.data.from == request.auth.uid || get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true);
        allow update: if false;
      }

      match /messages/{messageId} {
        allow read: if isSynthrunUser();
        allow create: if isSynthrunUser();
        allow delete: if get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true;
        allow update: if false;
      }
    }

    // Scheduled meetings — creator or admin can manage
    match /scheduled_meetings/{scheduledId} {
      allow read: if isSynthrunUser() && (resource.data.creatorId == request.auth.uid || get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true);
      allow create: if isSynthrunUser();
      allow update: if isSynthrunUser() && (resource.data.creatorId == request.auth.uid || get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true);
      allow delete: if isSynthrunUser() && (resource.data.creatorId == request.auth.uid || get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true);
    }

    // Connectors (API keys etc.) — admin only
    match /connectors/{docId} {
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/dashboard_users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
